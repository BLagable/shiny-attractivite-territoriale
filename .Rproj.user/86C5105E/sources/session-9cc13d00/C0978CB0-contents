  "score_infrastructures_numeriques"       = "Infrastructures numériques",
  "score_mobilite_accessibilite"           = "Mobilité et accessibilité"
)

labels_radar <- c(
  "score_dynamisme_economique_emploi"      = "Dynamisme\néconomique",
  "score_fiscalite_ressources_publiques"   = "Fiscalité &\nressources",
  "score_capital_humain_education"         = "Capital\nhumain",
  "score_services_equipements_qualite_vie" = "Services &\nqualité de vie",
  "score_demographie_structure_sociale"    = "Démographie",
  "score_logement_cadre_residentiel"       = "Logement",
  "score_environnement_risques"            = "Environnement\n& risques",
  "score_infrastructures_numeriques"       = "Infra.\nnumériques",
  "score_mobilite_accessibilite"           = "Mobilité &\naccessibilité"
)

cols_dim <- names(labels_radar)

descriptions <- list(
  "score_global"                           = "Score global d'attractivité entrepreneuriale — moyenne simple des 9 dimensions (OCDE/JRC 2008). Scores normalisés 0-100.",
  "score_dynamisme_economique_emploi"      = "Mesure l'activité économique locale, l'emploi, les revenus et la structure sectorielle du territoire.",
  "score_fiscalite_ressources_publiques"   = "Évalue la pression fiscale locale, les dépenses d'équipement des collectivités et les aides publiques.",
  "score_capital_humain_education"         = "Reflète le niveau de formation de la population et l'accès aux établissements d'enseignement supérieur.",
  "score_services_equipements_qualite_vie" = "Mesure la richesse de l'offre locale en services, équipements culturels, sportifs et de santé.",
  "score_demographie_structure_sociale"    = "Analyse la structure démographique, la densité et la participation civique.",
  "score_logement_cadre_residentiel"       = "Évalue la structure du parc de logements, le poids du logement social et le niveau des loyers.",
  "score_environnement_risques"            = "Prend en compte les risques naturels et industriels, la qualité environnementale et l'artificialisation.",
  "score_infrastructures_numeriques"       = "Mesure la couverture numérique : fibre optique, 4G et vitesse internet.",
  "score_mobilite_accessibilite"           = "Évalue l'accessibilité du territoire, les transports et les temps de trajet domicile-travail."
)

corr_creations <- sapply(names(labels_sous_indices), function(col) {
  if (col %in% colnames(data_scores) && "nombre_creations" %in% colnames(data_scores)) {
    round(cor(data_scores[[col]], data_scores$nombre_creations, use = "complete.obs"), 3)
  } else { NA }
})

