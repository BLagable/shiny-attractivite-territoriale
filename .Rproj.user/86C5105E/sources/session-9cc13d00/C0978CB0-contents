library(openxlsx)
library(sf)
library(dplyr)
library(readxl)
library(shiny)
library(shinyjs)
library(leaflet)
library(ggplot2)

# -----------------------------------------------------------------------------
# 0. Chargement et jointure
# -----------------------------------------------------------------------------

fond_carte_ze2020 <- st_read("data/ze2020_2024.shp") %>%
  rename(ZE2020 = ze2020, LIBZE2020 = libze2020)

data_scores <- readxl::read_xlsx("data/data_scores_ACP.xlsx") %>%
  mutate(ZE2020 = as.character(ZE2020))

fond_carte_data <- fond_carte_ze2020 %>%
  mutate(ZE2020 = as.character(ZE2020)) %>%
  left_join(data_scores %>% select(-LIBZE2020), by = "ZE2020")

