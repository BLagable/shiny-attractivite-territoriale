# -----------------------------------------------------------------------------
# 3. Server
# -----------------------------------------------------------------------------

server <- function(input, output, session) {

  # ---- Onglet 1 : Carte ----

  values_to_plot <- reactive({
    as.numeric(fond_carte_data[[input$variable]])
  })

  output$description <- renderText({
    desc <- descriptions[[input$variable]]
    if (is.null(desc)) "Description non disponible." else desc
  })

  output$avertissement_dim <- renderUI({
    if (input$variable %in% dims_correlation_negative) {
      div(class = "warning-box",
        tags$strong("Attention : "),
        "Un score élevé sur cette dimension ne reflète pas une attractivité favorable
         aux créations d'entreprises. Voir onglet Méthodologie."
      )
    }
  })

  output$moyenne_sous_indice <- renderText({
    vals <- values_to_plot()
    if (length(vals) > 0) round(mean(vals, na.rm = TRUE), 1) else "N/A"
  })

  output$correlation_creations <- renderUI({
    r <- corr_creations[[input$variable]]
    if (is.null(r) || is.na(r)) return(p("Non disponible", style = "color:#888;"))
    css_class <- if (r > 0.2) "corr-positive" else if (r < -0.1) "corr-negative" else "corr-neutral"
    direction <- if (r > 0) "positive" else "négative"
    intensite <- if (abs(r) > 0.4) "modérée à forte" else if (abs(r) > 0.2) "faible à modérée" else "très faible"
    HTML(paste0("<span class='", css_class, "'>r = ", sprintf("%.3f", r), "</span>",
                " — corrélation ", direction, " ", intensite, "."))
  })

  output$telecharger_donnees <- downloadHandler(
    filename = function() "attractivite_territoriale_ZE2020.xlsx",
    content  = function(file) {
      export_df <- data_scores %>%
        select(ZE2020, LIBZE2020, score_global, everything(), -nombre_creations)
      openxlsx::write.xlsx(export_df, file)
    }
  )

  output$map <- renderLeaflet({
    vals         <- values_to_plot()
    label_indice <- labels_sous_indices[[input$variable]]
    pal          <- colorQuantile("RdYlGn", vals, n = 4, na.color = "#cccccc")
    q            <- quantile(vals, probs = c(0.25, 0.5, 0.75), na.rm = TRUE)

    quartile_label <- ifelse(is.na(vals), "Données manquantes",
                      ifelse(vals >= q[3], "Quartile supérieur (Q4)",
                      ifelse(vals >= q[2], "3e quartile (Q3)",
                      ifelse(vals >= q[1], "2e quartile (Q2)",
                                           "Quartile inférieur (Q1)"))))

    leaflet(fond_carte_data) %>%
      addProviderTiles(providers$CartoDB.Positron) %>%
      addPolygons(
        fillColor   = ~pal(vals),
        weight      = 0.8,
        opacity     = 0.9,
        color       = "white",
        fillOpacity = 0.78,
        highlight   = highlightOptions(
          weight = 2, color = "#333333", fillOpacity = 0.92, bringToFront = TRUE
        ),
        label = ~lapply(paste0(
          "<strong>", LIBZE2020, "</strong><br>",
          label_indice, " : <strong>",
          ifelse(is.na(vals), "N/A", round(vals, 1)), " / 100</strong><br>",
          "<em style='color:#666666;'>", quartile_label, "</em>"
        ), htmltools::HTML),
        labelOptions = labelOptions(
          style    = list("font-weight" = "normal", padding = "6px 10px"),
          textsize = "13px", direction = "auto"
        )
      ) %>%
      addLegend(
        position = "bottomright",
        colors   = c("#1a9641", "#a6d96a", "#fdae61", "#d7191c"),
        labels   = c("Q4 — Quartile supérieur", "Q3 — 3e quartile",
                     "Q2 — 2e quartile",        "Q1 — Quartile inférieur"),
        title    = label_indice, opacity = 0.85
      ) %>%
      fitBounds(lng1 = -5.5, lat1 = 41.2, lng2 = 9.8, lat2 = 51.2)
  })

  # ---- Onglet 2 : Distribution ----

  output$distribution <- renderPlot({
    vals      <- values_to_plot()
    med       <- median(vals, na.rm = TRUE)
    q1        <- quantile(vals, 0.25, na.rm = TRUE)
    q3        <- quantile(vals, 0.75, na.rm = TRUE)
    label_i   <- labels_sous_indices[[input$variable]]
    var_col   <- input$variable

    # Score de la zone sélectionnée dans l'onglet Profil
    zone_score <- tryCatch({
      row <- data_scores %>% filter(LIBZE2020 == input$zone_profil)
      if (nrow(row) > 0) as.numeric(row[[var_col]][1]) else NA
    }, error = function(e) NA)

    p <- ggplot(data.frame(score = vals[!is.na(vals)]), aes(x = score)) +
      geom_histogram(bins = 30, fill = "#4a90d9", color = "white", alpha = 0.85) +
      geom_vline(xintercept = med, color = "red3",    linewidth = 1) +
      geom_vline(xintercept = q1,  color = "orange2", linewidth = 0.8, linetype = "dashed") +
      geom_vline(xintercept = q3,  color = "orange2", linewidth = 0.8, linetype = "dashed") +
      annotate("text", x = med, y = Inf, label = paste0("Médiane : ", round(med, 1)),
               vjust = 2, hjust = -0.1, color = "red3", size = 3.5) +
      annotate("text", x = q1, y = Inf, label = paste0("Q1 : ", round(q1, 1)),
               vjust = 2, hjust = 1.1, color = "orange2", size = 3) +
      annotate("text", x = q3, y = Inf, label = paste0("Q3 : ", round(q3, 1)),
               vjust = 2, hjust = -0.1, color = "orange2", size = 3)

    if (!is.na(zone_score)) {
      p <- p +
        geom_vline(xintercept = zone_score, color = "#2166AC", linewidth = 1.1,
                   linetype = "solid") +
        annotate("text", x = zone_score, y = Inf,
                 label = paste0(input$zone_profil, " : ", round(zone_score, 1)),
                 vjust = 2, hjust = -0.08, color = "#2166AC", size = 3.2)
    }

    p + labs(title = paste("Distribution —", label_i),
             x = "Score (0-100)", y = "Zones d'emploi") +
      theme_minimal(base_size = 12) +
      theme(plot.title = element_text(size = 13, face = "bold", color = "gray10"))
  })

  output$corr_plot <- renderPlot({
    corr_df <- data.frame(
      sous_indice = names(corr_creations),
      correlation = as.numeric(corr_creations)
    )
    corr_df$label   <- labels_sous_indices[corr_df$sous_indice]
    corr_df         <- corr_df[!is.na(corr_df$correlation), ]
    corr_df$couleur <- ifelse(corr_df$correlation > 0, "#2166AC", "#B2182B")
    corr_df$label   <- factor(corr_df$label, levels = corr_df$label[order(corr_df$correlation)])

    ggplot(corr_df, aes(x = correlation, y = label, fill = couleur)) +
      geom_col(width = 0.6, show.legend = FALSE) +
      geom_vline(xintercept = 0, color = "gray30", linewidth = 0.5) +
      geom_text(aes(label = sprintf("r = %.3f", correlation),
                    hjust = ifelse(correlation >= 0, -0.1, 1.1)),
                size = 3.2, color = "gray20") +
      scale_fill_identity() +
      scale_x_continuous(limits = c(-0.75, 0.85), expand = c(0, 0)) +
      labs(title = "Corrélation de Pearson entre chaque score ACP et le nombre de créations d'entreprises",
           subtitle = "Corrélations descriptives — 306 zones d'emploi (ZE2020). Aucune inférence causale.",
           x = "Corrélation (r)", y = NULL) +
      theme_minimal(base_size = 11) +
      theme(plot.title    = element_text(size = 11, face = "bold", color = "gray10"),
            plot.subtitle = element_text(size = 9, color = "gray40"),
            axis.text.y   = element_text(size = 10))
  })

  # ---- Onglet 3 : Profil territorial ----

  zone_data <- reactive({
    data_scores %>% filter(LIBZE2020 == input$zone_profil)
  })

  output$titre_radar <- renderText({ paste("Profil territorial —", input$zone_profil) })

  output$table_scores <- renderTable({
    z      <- zone_data()
    scores <- round(as.numeric(sapply(cols_dim, function(d) z[[d]])), 1)
    rangs  <- sapply(cols_dim, function(d) {
      rank(-data_scores[[d]], ties.method = "min")[data_scores$LIBZE2020 == input$zone_profil]
    })
    rang_g <- rank(-data_scores$score_global, ties.method = "min")[
      data_scores$LIBZE2020 == input$zone_profil]
    data.frame(
      Dimension   = c(as.character(labels_radar[cols_dim]), "Indice global"),
      Score       = c(scores, round(as.numeric(z$score_global), 1)),
      `Rang /306` = c(rangs, rang_g),
      check.names = FALSE
    )
  }, striped = TRUE, hover = TRUE, spacing = "s", digits = 1)

  # Fonction radar réutilisable
  make_radar <- function(scores_A, scores_B = NULL,
                         label_A = "Zone", label_B = NULL,
                         medians, labels, score_global_A = NULL, score_global_B = NULL) {
    n      <- length(labels)
    angles <- seq(0, 2 * pi, length.out = n + 1)[-(n + 1)]

    to_xy <- function(vals, angs) data.frame(
      x = (vals / 100) * cos(angs - pi / 2),
      y = (vals / 100) * sin(angs - pi / 2)
    )

    zone_xy   <- to_xy(c(scores_A, scores_A[1]), c(angles, angles[1]))
    median_xy <- to_xy(c(medians,  medians[1]),  c(angles, angles[1]))
    label_xy  <- to_xy(rep(120, n), angles)
    label_xy$label <- labels

    grille_df <- do.call(rbind, lapply(c(25, 50, 75, 100), function(v) {
      xy <- to_xy(rep(v, n + 1), c(angles, angles[1])); xy$niveau <- v; xy
    }))
    axes_df <- data.frame(x = cos(angles - pi/2), y = sin(angles - pi/2), xend = 0, yend = 0)

    p <- ggplot() +
      geom_path(data = grille_df, aes(x = x, y = y, group = niveau),
                color = "gray85", linewidth = 0.35) +
      geom_segment(data = axes_df, aes(x = x, y = y, xend = xend, yend = yend),
                   color = "gray75", linewidth = 0.4) +
      geom_polygon(data = median_xy, aes(x = x, y = y),
                   fill = "gray60", alpha = 0.18, color = "gray55", linewidth = 0.7) +
      geom_polygon(data = zone_xy, aes(x = x, y = y),
                   fill = "#2166AC", alpha = 0.30, color = "#2166AC", linewidth = 1.1) +
      geom_point(data = to_xy(scores_A, angles), aes(x = x, y = y),
                 color = "#2166AC", size = 2.5)

    if (!is.null(scores_B)) {
      zone_B_xy <- to_xy(c(scores_B, scores_B[1]), c(angles, angles[1]))
      p <- p +
        geom_polygon(data = zone_B_xy, aes(x = x, y = y),
                     fill = "#B2182B", alpha = 0.25, color = "#B2182B", linewidth = 1.1) +
        geom_point(data = to_xy(scores_B, angles), aes(x = x, y = y),
                   color = "#B2182B", size = 2.5)
    }

    # Labels dimensions
    p <- p + geom_text(data = label_xy, aes(x = x, y = y, label = label),
                       size = 2.8, lineheight = 0.88, color = "gray15")

    # Annotation score global sous le radar
    annotation <- if (!is.null(score_global_B)) {
      paste0(label_A, " : ", round(score_global_A, 1),
             "   |   ", label_B, " : ", round(score_global_B, 1))
    } else {
      paste0("Indice global : ", round(score_global_A, 1), " / 100")
    }

    p + annotate("text", x = 0, y = -1.55,
                 label = annotation,
                 size = 3, color = "#1a1a2e", fontface = "bold", hjust = 0.5) +
      coord_fixed(xlim = c(-1.4, 1.4), ylim = c(-1.55, 1.4)) +
      theme_void() +
      theme(plot.margin = margin(10, 10, 20, 10))
  }

  output$radar_plot <- renderPlot({
    z       <- zone_data()
    scores  <- as.numeric(sapply(cols_dim, function(d) z[[d]]))
    medians <- sapply(cols_dim, function(d) median(data_scores[[d]], na.rm = TRUE))
    labels  <- as.character(labels_radar[cols_dim])
    sg      <- as.numeric(z$score_global)

    make_radar(scores_A = scores, medians = medians, labels = labels,
               label_A = input$zone_profil, score_global_A = sg)
  })

  # ---- Onglet 4 : Comparaison ----

  zone_data_A <- reactive({ data_scores %>% filter(LIBZE2020 == input$zone_A) })
  zone_data_B <- reactive({ data_scores %>% filter(LIBZE2020 == input$zone_B) })

  output$titre_comparaison <- renderText({
    paste("Comparaison —", input$zone_A, "vs.", input$zone_B)
  })

  make_table_comp <- function(z, zone_name) {
    scores <- round(as.numeric(sapply(cols_dim, function(d) z[[d]])), 1)
    rangs  <- sapply(cols_dim, function(d) {
      rank(-data_scores[[d]], ties.method = "min")[data_scores$LIBZE2020 == zone_name]
    })
    rang_g <- rank(-data_scores$score_global, ties.method = "min")[
      data_scores$LIBZE2020 == zone_name]
    data.frame(
      Dimension   = c(as.character(labels_radar[cols_dim]), "Indice global"),
      Score       = c(scores, round(as.numeric(z$score_global), 1)),
      `Rang /306` = c(rangs, rang_g),
      check.names = FALSE
    )
  }

  output$table_comparaison_A <- renderTable({
    make_table_comp(zone_data_A(), input$zone_A)
  }, striped = TRUE, hover = TRUE, spacing = "s", digits = 1)

  output$table_comparaison_B <- renderTable({
    make_table_comp(zone_data_B(), input$zone_B)
  }, striped = TRUE, hover = TRUE, spacing = "s", digits = 1)

  output$radar_comparaison <- renderPlot({
    zA      <- zone_data_A()
    zB      <- zone_data_B()
    scores_A <- as.numeric(sapply(cols_dim, function(d) zA[[d]]))
    scores_B <- as.numeric(sapply(cols_dim, function(d) zB[[d]]))
    medians  <- sapply(cols_dim, function(d) median(data_scores[[d]], na.rm = TRUE))
    labels   <- as.character(labels_radar[cols_dim])

    make_radar(
      scores_A = scores_A, scores_B = scores_B,
      label_A  = input$zone_A, label_B = input$zone_B,
      medians  = medians, labels = labels,
      score_global_A = as.numeric(zA$score_global),
      score_global_B = as.numeric(zB$score_global)
    )
  })

