      mutate(
        LIBZE2020 = factor(LIBZE2020, levels = LIBZE2020),
        couleur   = if (input$sens_classement == "top") "#2166AC" else "#B2182B"
      )

    ggplot(df, aes(x = valeur, y = LIBZE2020, fill = couleur)) +
      geom_col(width = 0.72, show.legend = FALSE) +
      geom_text(aes(label = round(valeur, 1), hjust = -0.15), size = 3.3, color = "gray20") +
      scale_fill_identity() +
      scale_x_continuous(limits = c(0, 108), expand = c(0, 0)) +
      labs(x = "Score (0-100)", y = NULL,
           caption = "OCDE/JRC (2008). Scores ACP normalisés min-max. 306 zones d'emploi ZE2020.") +
      theme_minimal(base_size = 11) +
      theme(axis.text.y        = element_text(size = 10.5, color = "gray10"),
            plot.caption       = element_text(size = 8, color = "gray50", hjust = 0),
            panel.grid.major.y = element_blank())
  })
