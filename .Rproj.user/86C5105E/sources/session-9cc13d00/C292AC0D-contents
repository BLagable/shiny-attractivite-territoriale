corr_creations <- sapply(names(labels_sous_indices), function(col) {
  if (col %in% colnames(data_scores) && "nombre_creations" %in% colnames(data_scores)) {
    round(cor(data_scores[[col]], data_scores$nombre_creations, use = "complete.obs"), 3)
  } else { NA }
})

